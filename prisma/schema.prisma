generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Letter {
  id                String   @id @default(uuid())
  title             String
  sender            String?
  status            String   @default("PENDING")
  analysisResult    String?
  createdAt         DateTime @default(now())
}
